{
  "name": "nest-native-asyncapi-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Community standalone monorepo for @nest-native/asyncapi",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "sample/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "TS_NODE_PROJECT=tsconfig.spec.json node --require ts-node/register --require reflect-metadata --test packages/asyncapi/test/*.spec.ts",
    "test:report": "node scripts/run-node-test-report.cjs",
    "test:cov": "c8 --all --include \"packages/asyncapi/**/*.ts\" --exclude \"packages/asyncapi/test/**\" --exclude \"packages/asyncapi/interfaces.ts\" --exclude \"packages/asyncapi/index.ts\" --exclude \"**/*.d.ts\" --exclude \"**/dist/**\" --reporter text --reporter text-summary --reporter json-summary --reporter lcov --check-coverage --branches 100 --functions 100 --lines 100 --statements 100 npm run test:report",
    "test:watch": "TS_NODE_PROJECT=tsconfig.spec.json node --watch --require ts-node/register --require reflect-metadata --test packages/asyncapi/test/*.spec.ts",
    "test:mutation": "stryker run",
    "test:mutation:full": "stryker run --force",
    "test:mutant": "TS_NODE_PROJECT=tsconfig.spec.json node --require ts-node/register --require reflect-metadata --test --test-force-exit packages/asyncapi/test/*.spec.ts",
    "complexity:check": "eslint --config eslint.complexity-check.config.mjs \"packages/asyncapi/**/*.ts\"",
    "complexity:report": "node scripts/collect-cognitive-complexity.mjs",
    "release:check:readme-links": "node scripts/check-readme-links.mjs",
    "release:check:sample-versions": "node scripts/check-sample-version-sync.mjs",
    "release:check:pack": "npm run build --workspace @nest-native/asyncapi && node scripts/check-package-pack.mjs",
    "release:check": "npm run release:check:readme-links && npm run release:check:sample-versions && npm run release:check:pack",
    "ci:docs": "npm --prefix website ci && npm --prefix website run build",
    "security:audit:package": "node scripts/audit-production-surface.mjs",
    "security:audit:docs": "npm --prefix website audit --audit-level=high",
    "security:audit": "npm run security:audit:package && npm run security:audit:docs",
    "showcase": "node scripts/run-optional-workspace.cjs nest-native-asyncapi-showcase test",
    "sample:focused": "node scripts/run-focused-samples.mjs",
    "sample": "npm run showcase && npm run sample:focused",
    "ci:sample": "npm run sample",
    "ci": "npm run typecheck && npm run test:cov && npm run complexity:check && npm run complexity:report && npm run release:check && npm run ci:docs && npm run security:audit && npm run ci:sample"
  },
  "engines": {
    "node": ">=20"
  },
  "scarfSettings": {
    "enabled": false
  },
  "devDependencies": {
    "@asyncapi/parser": "^3.4.0",
    "@nestjs/common": "^11.1.26",
    "@nestjs/core": "^11.1.26",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/testing": "^11.1.27",
    "@stryker-mutator/core": "^9.6.1",
    "@types/node": "^26.0.1",
    "@typescript-eslint/parser": "^8.62.0",
    "c8": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "eslint": "^10.6.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.1.3",
    "rxjs": "^7.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "packageManager": "npm@11.13.0",
  "overrides": {
    "multer": "^2.2.0"
  }
}
